package com.lpu.library;

import java.util.*;

class Book {
    private int bookId;
    private String title;
    private String author;
    private boolean availability;

    Book(int bookId, String title, String author) {
        this.bookId = bookId;
        this.title = title;
        this.author = author;
        this.availability = true;
    }

    public int getBookId() {
        return bookId;
    }

    public String getTitle() {
        return title;
    }

    public String getAuthor() {
        return author;
    }

    public boolean isAvailable() {
        return availability;
    }

    public void setAvailability(boolean availability) {
        this.availability = availability;
    }

    public void display() {
        System.out.println(bookId + " | " + title + " | " + author + " | " + (availability ? "Available" : "Issued"));
    }
}

class Member {
    protected int memberId;
    protected String name;

    Member(int memberId, String name) {
        this.memberId = memberId;
        this.name = name;
    }

    public int getMemberId() {
        return memberId;
    }
}

class StudentMember extends Member {

    StudentMember(int memberId, String name) {
        super(memberId, name);
    }

    public double calculateFine(int days) {
        return days * 1.0;
    }
}

class Library {
    private ArrayList<Book> books = new ArrayList<>();
    private HashMap<Integer, ArrayList<Book>> issuedBooks = new HashMap<>();

    public void addBook(Book book) {
        books.add(book);
        System.out.println("Book Added");
    }

    public void displayBooks() {
        for (Book b : books) {
            b.display();
        }
    }

    public void issueBook(int memberId, int bookId) {
        for (Book b : books) {
            if (b.getBookId() == bookId && b.isAvailable()) {
                b.setAvailability(false);

                issuedBooks.putIfAbsent(memberId, new ArrayList<>());
                issuedBooks.get(memberId).add(b);

                System.out.println("Book Issued");
                return;
            }
        }
        System.out.println("Book not available");
    }

    public void returnBook(int memberId, int bookId) {
        if (issuedBooks.containsKey(memberId)) {
            ArrayList<Book> list = issuedBooks.get(memberId);

            for (Book b : list) {
                if (b.getBookId() == bookId) {
                    b.setAvailability(true);
                    list.remove(b);
                    System.out.println("Book Returned");
                    return;
                }
            }
        }
        System.out.println("Invalid return");
    }

    public void search(String title) {
        for (Book b : books) {
            if (b.getTitle().equalsIgnoreCase(title)) {
                b.display();
            }
        }
    }

    public void search(String title, String author) {
        for (Book b : books) {
            if (b.getTitle().equalsIgnoreCase(title) || b.getAuthor().equalsIgnoreCase(author)) {
                b.display();
            }
        }
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Library lib = new Library();

        while (true) {
            System.out.println("\n1.Add Book 2.Display 3.Issue 4.Return 5.Search 6.Exit");
            int ch = sc.nextInt();

            switch (ch) {
                case 1:
                    int id = sc.nextInt();
                    sc.nextLine();
                    String title = sc.nextLine();
                    String author = sc.nextLine();
                    lib.addBook(new Book(id, title, author));
                    break;

                case 2:
                    lib.displayBooks();
                    break;

                case 3:
                    int mId = sc.nextInt();
                    int bId = sc.nextInt();
                    lib.issueBook(mId, bId);
                    break;

                case 4:
                    mId = sc.nextInt();
                    bId = sc.nextInt();
                    lib.returnBook(mId, bId);
                    break;

                case 5:
                    sc.nextLine();
                    String t = sc.nextLine();
                    lib.search(t);
                    break;

                case 6:
                    return;
            }
        }
    }
}
